{
  "name": "@effect-admin/example",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Vite + Effect HttpApi example for effect-admin",
  "scripts": {
    "predev": "pnpm --filter @effect-admin/react^... build && pnpm --filter @effect-admin/react build",
    "dev": "concurrently -k -n api,web 'pnpm dev:server' 'pnpm dev:web'",
    "dev:server": "tsx src/server.ts",
    "dev:web": "vite",
    "build": "vite build"
  },
  "dependencies": {
    "@effect-admin/annotations": "workspace:*",
    "@effect-admin/contracts": "workspace:*",
    "@effect-admin/core": "workspace:*",
    "@effect-admin/react": "workspace:*",
    "@effect/platform": "^0.96.2",
    "@effect/platform-node": "^0.107.0",
    "effect": "^3.21.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "concurrently": "^9.2.0",
    "tsx": "^4.23.0",
    "vite": "^7.0.0"
  }
}
