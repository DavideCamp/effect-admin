{
  "name": "@effect-admin/example",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Example host app: first consumer and test gym of effect-admin (blog + shop domain)",
  "scripts": {
    "dev": "tsx src/server.ts",
