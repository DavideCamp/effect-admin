    "@effect-admin/sql": "workspace:*",
    "@effect-admin/web": "workspace:*",
    "@effect/platform": "^0.96.2",
    "@effect/platform-node": "^0.107.0",
    "@effect/sql": "^0.51.1",
    "@effect/sql-pg": "^0.52.1",
    "effect": "^3.21.4"
  },
  "devDependencies": {
    "tsx": "^4.23.0"
  }
}
