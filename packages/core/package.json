{
  "name": "@effect-admin/core",
  "version": "0.1.3",
  "type": "module",
  "description": "Effect Schema introspection, CRUD conventions, and admin resource definitions",
  "keywords": [
    "effect",
    "effect-admin",
    "httpapi",
    "schema",
    "admin"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "development": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "dependencies": {
    "@effect-admin/annotations": "workspace:*",
    "@effect-admin/contracts": "workspace:*"
  },
  "peerDependencies": {
    "@effect/platform": "^0.96.2",
    "effect": "^3.21.4"
  },
  "devDependencies": {
    "@effect/platform": "^0.96.2",
    "effect": "^3.21.4"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DavideCamp/effect-admin.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/DavideCamp/effect-admin#readme",
  "bugs": {
    "url": "https://github.com/DavideCamp/effect-admin/issues"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -b tsconfig.build.json --force",
    "prepack": "pnpm build"
  },
  "publishConfig": {
    "access": "public",
    "tag": "alpha",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  }
}
