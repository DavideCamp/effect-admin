{
  "name": "@effect-admin/web",
  "version": "0.1.0",
  "type": "module",
  "description": "effect-admin web: mountable HTTP router (JSON API + server-generated UI)",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "dependencies": {
    "@effect-admin/core": "workspace:*"
  },
  "peerDependencies": {
    "@effect/platform": "^0.96.2",
    "effect": "^3.21.4"
  },
  "devDependencies": {
    "@effect/platform": "^0.96.2",
    "effect": "^3.21.4"
  },
  "license": "MIT",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b tsconfig.build.json && rm -rf dist/ui && cp -R src/ui dist/ui"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  }
}
