{
  "name": "@effect-admin/effect4",
  "version": "0.1.0",
  "type": "module",
  "description": "Effect 4 HttpApi adapter, resource definitions, and client integration for effect-admin",
  "keywords": [
    "effect",
    "effect-admin",
    "effect4",
    "httpapi",
    "admin"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "development": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "dependencies": {
    "@effect-admin/annotations": "workspace:*",
    "@effect-admin/shared": "workspace:*"
  },
  "peerDependencies": {
    "effect": ">=4.0.0-beta.98 <5"
  },
  "devDependencies": {
    "effect": "4.0.0-beta.98",
    "typescript": "^5.9.3"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DavideCamp/effect-admin.git",
    "directory": "packages/effect4"
  },
  "homepage": "https://github.com/DavideCamp/effect-admin#readme",
  "bugs": {
    "url": "https://github.com/DavideCamp/effect-admin/issues"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -b tsconfig.build.json --force",
    "typecheck": "tsc -p tsconfig.test.json",
    "prepack": "pnpm build"
  },
  "publishConfig": {
    "access": "public",
    "tag": "alpha",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  }
}
