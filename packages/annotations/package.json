{
  "name": "@effect-admin/annotations",
  "version": "0.1.1",
  "type": "module",
  "description": "Zero-dependency annotation entrypoint: the only coupling a host app needs to effect-admin",
  "keywords": [
    "effect",
    "effect-admin",
    "schema",
    "admin",
    "annotations"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "development": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DavideCamp/effect-admin.git",
    "directory": "packages/annotations"
  },
  "homepage": "https://github.com/DavideCamp/effect-admin#readme",
  "bugs": {
    "url": "https://github.com/DavideCamp/effect-admin/issues"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -b tsconfig.build.json --force",
    "prepack": "pnpm build"
  },
  "publishConfig": {
    "access": "public",
    "tag": "alpha",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  }
}
